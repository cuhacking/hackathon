{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../../apps/hacker-portal/.next/types/**/*.ts",
    "../../dist/apps/hacker-portal/.next/types/**/*.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "eslint.config.mjs",
    "postcss.config.cjs",
    "jest.config.ts",
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
